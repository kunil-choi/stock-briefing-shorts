# .env.example — 실제 값은 절대 커밋하지 말 것. 로컬에서 .env로 복사해 채워 사용.

# ── 스크립트 생성(필수) ──────────────────────────────────────────────────
OPENAI_API_KEY=

# ── 프리미엄 TTS (선택 — 없으면 OpenAI TTS로 자동 폴백) ────────────────────
# ELEVENLABS_VOICE_ID는 pipeline/update_voice_id.py로 voice_sample/의 녹음에서
# 미리 만들어둔 클론 목소리 ID다(STEP-1/STEP-2와 동일한 목소리 사용 권장).
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── 연합뉴스/KBS 이미지 검색 (선택 — 없어도 공개 검색 페이지로 동작) ────────
YONHAP_API_KEY=
KBS_API_KEY=
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
ENABLE_NAVER_DISCOVERY=false

# ── 오프라인 드라이런 ───────────────────────────────────────────────────
SCRIPT_MOCK=
TTS_MOCK=
MEDIA_MOCK=
